# Server port
PORT=5000

# development | production
NODE_ENV=development

# Comma-separated list of allowed origins, e.g. https://app.example.com
# "*" allows any origin (fine for local dev / demos)
CORS_ORIGIN=*

# Room limits
MAX_USERS_PER_ROOM=12
MAX_ROOMS=500

# Max document size in bytes (default 256KB)
MAX_CODE_BYTES=262144

# How long an empty room keeps its document (ms, default 10 minutes)
EMPTY_ROOM_TTL_MS=600000

# Idle empty rooms older than this are swept (ms, default 24 hours)
STALE_ROOM_TTL_MS=86400000

# Socket.IO payload ceiling in bytes — keep above MAX_CODE_BYTES (default 1MB)
MAX_HTTP_BUFFER_SIZE=1000000

# debug | info | warn | error
LOG_LEVEL=info
